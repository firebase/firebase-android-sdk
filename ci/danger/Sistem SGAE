### 3. `sync_portfolio.py` – ETL Script (Google Cloud Functions / Scheduler)

```python
import requests
from google.cloud import firestore, bigquery
import redis
import json
from datetime import datetime

def sync_data(event, context):
    # 1. Ambil data portfolio dari API Gateway
    resp = requests.get("https://api.sgae.endai.global/api/v1/portfolio/unified",
                        headers={"X-ZTA-Key": "ZTA-2026-MY-07B3"})
    if resp.status_code != 200:
        print(f"API error: {resp.status_code}")
        return
    data = resp.json()
    
    # 2. Simpan telemetri & ledger ke Firestore
    db = firestore.Client()
    db.collection("telemetry").document("current").set(data["telemetry"])
    db.collection("ledger").document("summary").set(data["financial"])
    
    # 3. Log ke BigQuery
    client = bigquery.Client()
    table_id = "sgae_project.ledger_analytics"
    rows_to_insert = [{
        "sgae_index": data["telemetry"].get("sgae_index", 0),
        "predicted_index": data["telemetry"].get("predicted_index", 0),
        "threats_blocked": data["telemetry"].get("threats_blocked", 0),
        "timestamp": data["timestamp"]
    }]
    errors = client.insert_rows_json(table_id, rows_to_insert)
    if errors:
        print(f"BigQuery errors: {errors}")
    
    # 4. Kemaskini Redis untuk WebSocket
    redis_client = redis.Redis(host='localhost', port=6379)
    redis_client.set("latest_telemetry", json.dumps(data["telemetry"]))
    
    print("Sync completed at", datetime.utcnow())

# Untuk local testing
