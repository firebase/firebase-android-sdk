// MODUL 3: PENGURUS WEBSOCKET PINTAR
// ============================================================
class SovereignWSManager {
    constructor() {
        this.ws = null;
        this.isConnected = false;
        this.reconnectAttempts = 0;
        this.maxReconnect = 10;
        this.url = 'wss://api.sgae.endai.global/ws/live-telemetry';
        this.logContainer = document.getElementById('wsLogContainer');
        this.stateEl = document.getElementById('wsConnectionState');
    }

    log(msg, type = 'info') {
        const prefix = type === 'error' ? '🔴' : type === 'success' ? '🟢' : '📡';
        this.logContainer.innerHTML += `<div>[${new Date().toLocaleTimeString()}] ${prefix} ${msg}</div>`;
        this.logContainer.scrollTop = this.logContainer.scrollHeight;
        if (this.logContainer.children.length > 50) {
            this.logContainer.removeChild(this.logContainer.children[0]);
        }
    }

    connect() {
        if (this.ws && this.isConnected) { this.log('Sudah bersambung!', 'info'); return; }
        this.log('Menghubungkan ke ' + this.url + '...', 'info');
        this.stateEl.innerText = 'Menghubung...';
        this.stateEl.style.color = 'var(--gold)';
        
        this.ws = new WebSocket(this.url);
        
        this.ws.onopen = () => {
            this.isConnected = true;
            this.reconnectAttempts = 0;
            this.log('✅ Sambungan WebSocket BERJAYA!', 'success');
            this.stateEl.innerText = '🟢 Connected';
            this.stateEl.style.color = 'var(--green)';
            document.getElementById('wsStatus').innerText = '✅ Connected';
            document.getElementById('wsStatus').style.color = 'var(--green)';
        };
        
        this.ws.onmessage = (event) => {
            try {
                const data = JSON.parse(event.data);
                // Update telemetry widgets if needed
                if (data.sgae_index) {
                    document.getElementById('currentIndex').innerText = data.sgae_index;
                }
                if (data.predicted_index) {
                    document.getElementById('predictedIndex').innerText = data.predicted_index;
                }
                this.log(`📊 Data diterima: SGAE=${data.sgae_index || 'N/A'}`, 'info');
            } catch (e) {
                this.log(`📨 Raw: ${event.data.substring(0,50)}...`, 'info');
            }
        };
        
        this.ws.onerror = (error) => {
            this.log(`❌ Ralat WebSocket: ${error.type}`, 'error');
        };
        
        this.ws.onclose = (event) => {
            this.isConnected = false;
            this.log(`🔴 Sambungan ditutup (${event.code}).`, 'error');
            this.stateEl.innerText = '🔴 Disconnected';
            this.stateEl.style.color = 'var(--rose)';
            document.getElementById('wsStatus').innerText = '⏳ Disconnected';
            document.getElementById('wsStatus').style.color = 'var(--gold)';
            // Auto reconnect
            if (this.reconnectAttempts < this.maxReconnect) {
                this.reconnectAttempts++;
                const delay = Math.min(5000, 1000 * this.reconnectAttempts);
                this.log(`⏳ Cuba sambung semula dalam ${delay/1000}s (${this.reconnectAttempts}/${this.maxReconnect})`, 'info');
                setTimeout(() => this.connect(), delay);
            } else {
                this.log('❌ Gagal sambung semula. Sila semak backend.', 'error');
            }
        };
    }
    
    disconnect() {
        if (this.ws) {
            this.ws.close(1000, 'Pengguna putus sambungan');
            this.ws = null;
            this.isConnected = false;
