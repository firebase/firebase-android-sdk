// ============================================================
// MODUL 1: TANDATANGAN DIGITAL BERDAULAT (Web Crypto)
// ============================================================
let sovereignKeyPair = null;
let currentSignature = null;

async function generateSovereignKeys() {
    try {
        const keyPair = await window.crypto.subtle.generateKey(
            { name: "ECDSA", namedCurve: "P-256" },
            true,
            ["sign", "verify"]
        );
        sovereignKeyPair = keyPair;
        
        // Export public key as base64
        const rawPub = await window.crypto.subtle.exportKey("spki", keyPair.publicKey);
        const pubBase64 = btoa(String.fromCharCode(...new Uint8Array(rawPub)));
        document.getElementById('publicKeyDisplay').innerText = pubBase64.substring(0, 48) + '...';
        showToast('🔑 Kunci ECDSA P-256 berjaya dijana!');
    } catch (e) {
        showToast('❌ Gagal menjana kunci: ' + e.message);
    }
}

async function signMessage() {
    if (!sovereignKeyPair) { showToast('⚠️ Jana kunci dahulu!'); return; }
    const msg = document.getElementById('signMessageInput').value;
    if (!msg) { showToast('⚠️ Taip mesej!'); return; }
    
    const encoder = new TextEncoder();
    const data = encoder.encode(msg);
    
    try {
        const signature = await window.crypto.subtle.sign(
            { name: "ECDSA", hash: { name: "SHA-256" } },
            sovereignKeyPair.privateKey,
            data
        );
        currentSignature = btoa(String.fromCharCode(...new Uint8Array(signature)));
        document.getElementById('signatureDisplay').innerText = currentSignature.substring(0, 60) + '...';
        document.getElementById('verifyStatus').innerText = '⏳ Belum disahkan';
        showToast('✍️ Mesej ditandatangani!');
    } catch (e) {
        showToast('❌ Ralat menandatangani: ' + e.message);
    }
}

async function verifySignature() {
    if (!sovereignKeyPair || !currentSignature) { showToast('⚠️ Jana kunci & tandatangan dahulu!'); return; }
    const msg = document.getElementById('signMessageInput').value;
    const encoder = new TextEncoder();
    const data = encoder.encode(msg);
    const sigBytes = Uint8Array.from(atob(currentSignature), c => c.charCodeAt(0));
    
    try {
        const isValid = await window.crypto.subtle.verify(
            { name: "ECDSA", hash: { name: "SHA-256" } },
            sovereignKeyPair.publicKey,
            sigBytes,
            data
        );
        document.getElementById('verifyStatus').innerHTML = isValid ? 
            '<span style="color:var(--green);">✅ SAH! Tandatangan sah milik Muhamad Sazwan.</span>' : 
            '<span style="color:var(--rose);">❌ TIDAK SAH! Data telah diubah.</span>';
        showToast(isValid ? '✅ Tandatangan disahkan!' : '❌ Tandatangan tidak sah!');
    } catch (e) {
        showToast('❌ Ralat pengesahan: ' + e.message);
    }
}

