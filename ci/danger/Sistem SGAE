from fastapi import FastAPI, WebSocket, WebSocketDisconnect, Depends, HTTPException, Request
from fastapi.middleware.cors import CORSMiddleware
from firebase_admin import credentials, firestore, initialize_app
import asyncpg
import redis.asyncio as redis
import json
import os
from datetime import datetime
import asyncio

# === Firebase Init ===
cred = credentials.Certificate("serviceAccountKey.json")
firebase_app = initialize_app(cred)
db_firestore = firestore.client()

# === PostgreSQL Connection Pool ===
DATABASE_URL = os.getenv("DATABASE_URL", "postgresql://user:pass@dataconnect.msi-sazwan.digital/sgae")
async def get_db():
    conn = await asyncpg.connect(DATABASE_URL)
    try:
        yield conn
    finally:
        await conn.close()

# === Redis Cache (untuk telemetri) ===
redis_client = redis.from_url("redis://localhost:6379", decode_responses=True)

app = FastAPI(title="SGAE 2.0 Sovereign Portfolio API", version="2.0.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ===== Middleware Zero Trust =====
@app.middleware("http")
async def verify_zta(request: Request, call_next):
    zta_key = request.headers.get("X-ZTA-Key")
    # Allow public verification endpoint without ZTA key
    if request.url.path.startswith("/v1/verify/"):
        response = await call_next(request)
        return response
    if zta_key != "ZTA-2026-MY-07B3":
        raise HTTPException(status_code=401, detail="Invalid Zero Trust Key")
    response = await call_next(request)
    return response

# ===== Endpoint: Gabungan Portfolio =====
@app.get("/api/v1/portfolio/unified")
async def get_unified_portfolio(conn=Depends(get_db)):
    identity = await conn.fetchrow("SELECT * FROM sgae.identity LIMIT 1")
    urls = await conn.fetch("SELECT * FROM sgae.portfolio_urls WHERE health_status='ACTIVE'")
    myipo = await conn.fetch("SELECT * FROM sgae.myipo_registrations WHERE status='ACTIVE'")
    
    # Ledger dari Firestore (untuk data masa nyata)
    ledger_doc = db_firestore.collection("ledger").document("summary").get()
    ledger = ledger_doc.to_dict() if ledger_doc.exists else {}
    
    # Telemetri dari Redis (cache dari WebSocket)
    telemetry = await redis_client.get("latest_telemetry")
    telemetry = json.loads(telemetry) if telemetry else {}
    
    return {
        "status": "ACTIVE",
        "identity": dict(identity),
        "financial": ledger,
        "telemetry": telemetry,
        "active_urls": [dict(u) for u in urls],
        "myipo": [dict(r) for r in myipo],
        "timestamp": datetime.utcnow().isoformat()
    }

# ===== WebSocket: Live Telemetry =====
@app.websocket("/ws/live-telemetry")
async def websocket_telemetry(websocket: WebSocket):
    await websocket.accept()
    try:
        while True:
            data = await redis_client.get("latest_telemetry")
            if data:
                await websocket.send_text(data)
            else:
                # Fallback
                fallback = {
                    "server_cpu": "23%",
                    "server_ram": "4.2 GB / 256 GB",
                    "threats_blocked": 12847,
                    "sgae_index": 1195,
                    "predicted_index": 1242,
                    "uptime": "99.98%",
                    "block_height": 847221
                }
                await websocket.send_text(json.dumps(fallback))
            await asyncio.sleep(3)
    except WebSocketDisconnect:
        print("WebSocket disconnected")

# ===== Endpoint Verifikasi Identity =====
@app.get("/v1/verify/{global_id}")
async def verify_identity(global_id: str, conn=Depends(get_db)):
    identity = await conn.fetchrow(
        "SELECT full_name, sha256_hash, zero_trust_key FROM sgae.identity WHERE global_id = $1",
        global_id
    )
    if not identity:
        raise HTTPException(status_code=404, detail="Identity not found")
    return dict(identity)
